# local-router configuration.
#
# Copy this file to .env and run the setup script:
#
#   cp .env.example .env
#   ./router.sh up
#
# Every value below has a working default, so an unedited copy serves the
# Qwen2.5 0.5B model through Ollama on http://127.0.0.1:8080/v1. Edit only the
# lines you care about.

# Router-facing model id. Must match an entry in models/catalog.yaml.
#ROUTER_MODEL=qwen2.5-0.5b-instruct

# Runtime that serves the model: ollama or llama_cpp.
# ollama is fully automated by router.sh (install, model pull, serve).
ROUTER_BACKEND=ollama

# Address the router listens on. Keep 127.0.0.1 when fronting it with nginx
# (./router.sh nginx). Use 0.0.0.0 to accept remote traffic directly.
ROUTER_HOST=127.0.0.1
ROUTER_PORT=8080

# Context window the router advertises and asks the backend to use.
#ROUTER_CONTEXT_LENGTH=16384

# Auth for /v1 endpoints: api_key_only, ip_only, ip_or_key, ip_and_key, disabled.
# router.sh provisions a key automatically when the chosen mode needs one.
ROUTER_AUTH_MODE=api_key_only

# Hashed key store and usage log. Defaults live under .run/ (kept out of git).
ROUTER_KEY_STORE=.run/keys.json
ROUTER_LOG_PATH=.run/usage.jsonl

# Public URL clients use to reach the router, when it differs from host:port
# (for instance when nginx terminates on port 80).
# ROUTER_PUBLIC_BASE_URL=http://YOUR_PUBLIC_IP/v1

# ---- OpenCode integration ----
# router.sh writes an OpenCode provider config here on `up`. Launch OpenCode
# against it with: opencode --config opencode.local-router.json
OPENCODE_CONFIG=opencode.local-router.json

# ---- ollama backend ----
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# Ollama tag to pull. Leave blank to derive it from the catalog entry above.
OLLAMA_MODEL_TAG=

# ---- llama.cpp backend (only when ROUTER_BACKEND=llama_cpp) ----
# Point this at a llama-server you already run. The minimal/ folder ships a
# self-contained GGUF server if you want one in a few commands.
LLAMA_BASE_URL=http://127.0.0.1:8081/v1
# GPU offload hint for a router-managed llama-server: off, all, auto, or a count.
LLAMA_GPU_LAYERS=off
#
# Example: serve Gemma 4 12B (GGUF) with its full 256K context via llama.cpp.
# Start llama-server with --ctx-size 262144 first (see the README "256K context"
# section), then set:
#ROUTER_BACKEND=llama_cpp
ROUTER_MODEL=gemma-4-12b-qat
ROUTER_CONTEXT_LENGTH=262144
#LLAMA_BASE_URL=http://127.0.0.1:8081/v1
